<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle" xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>StatBar Updates</title>
    <link>https://getstatbar.com/appcast.xml</link>
    <description>Most recent StatBar releases.</description>
    <language>en</language>
    <!--
      One <item> per release. The `sparkle:edSignature` is produced by
      Sparkle's `sign_update` tool against the .dmg/.zip and must match the
      SUPublicEDKey in Info.plist. `length` is the file size in bytes.
      Regenerate this file with Sparkle's `generate_appcast` against the
      directory holding your signed builds — it fills signatures + lengths.
    -->
    <item>
      <title>Version 1.0</title>
      <description><![CDATA[
        <ul>
          <li>Initial public release of StatBar.</li>
        </ul>
      ]]></description>
      <pubDate>Tue, 17 Jun 2026 00:00:00 +0000</pubDate>
      <sparkle:version>1</sparkle:version>
      <sparkle:shortVersionString>1.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
      <enclosure
        url="https://getstatbar.com/releases/StatBar-1.0.dmg"
        sparkle:version="1"
        sparkle:shortVersionString="1.0"
        sparkle:edSignature="REPLACE_WITH_ED_SIGNATURE"
        length="0"
        type="application/octet-stream" />
    </item>
  </channel>
</rss>
